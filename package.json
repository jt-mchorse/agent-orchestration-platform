{
  "name": "agent-orchestration-platform",
  "version": "0.1.0",
  "private": true,
  "description": "PR review agent: tool registry, custom MCP server, HITL checkpoints, full trace observability, eval suite.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "portfolio-context-mcp": "dist/mcp-server/portfolio-context/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "trace:server": "tsx src/bin/trace-server.ts",
    "eval": "tsx src/bin/eval-runner.ts",
    "validate": "tsx src/bin/validate.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "js-yaml": "^4.2.0",
    "pg": "^8.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
